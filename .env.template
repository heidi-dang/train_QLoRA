# QLoRA Training Pipeline Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# TEACHER API CONFIGURATION
# =============================================================================
# Your Teacher API Key (Grok/OpenAI/Anthropic)
TEACHER_API_KEY=YOUR_TEACHER_API_KEY_HERE

# Teacher provider: grok|openai|copilot
# - grok/openai require TEACHER_API_KEY
# - copilot uses GitHub auth (gh auth login + gh copilot login)
TEACHER_PROVIDER=grok

# Teacher model to use
TEACHER_MODEL=grok-4-1-fast

# Copilot model to use when TEACHER_PROVIDER=copilot
TEACHER_COPILOT_MODEL=gpt-5-mini

# =============================================================================
# DASHBOARD CONFIGURATION
# =============================================================================
# Pin dashboard log source: loop|api|mlflow|tb|dashboard
DASHBOARD_LOG_SOURCE=loop

# =============================================================================
# AUTO ORCHESTRATION (GENERATE <-> TRAIN)
# =============================================================================
# If true, when enough clean samples already exist, train/evaluate first then
# return to scraping/generation/cleaning to top up data.
AUTO_TRAIN_FIRST=true

# Minimum number of cleaned samples required to start a training run.
MIN_SAMPLES_TO_TRAIN=200

# If cleaned samples drop below this, run scrape/generate/clean to replenish.
TARGET_BUFFER_SAMPLES=500

# =============================================================================
# PRICING CONFIGURATION
# =============================================================================
# Grok-4-1-fast pricing (adjust for your model)
GROK_4_1_FAST_INPUT_PRICE=0.20
GROK_4_1_FAST_OUTPUT_PRICE=0.50

# OpenAI GPT-4 pricing (for reference)
GPT_4_INPUT_PRICE=0.03
GPT_4_OUTPUT_PRICE=0.06

# OpenAI GPT-3.5-turbo pricing (for reference)
GPT_3_5_TURBO_INPUT_PRICE=0.0015
GPT_3_5_TURBO_OUTPUT_PRICE=0.002

# Anthropic Claude-3 pricing (for reference)
CLAUDE_3_SONNET_INPUT_PRICE=0.015
CLAUDE_3_SONNET_OUTPUT_PRICE=0.075

# =============================================================================
# HUGGINGFACE CONFIGURATION
# =============================================================================
# Your HuggingFace Token (optional, for private models)
HF_TOKEN=YOUR_HUGGINGFACE_TOKEN_HERE

# =============================================================================
# TRAINING CONFIGURATION
# =============================================================================
# Languages to train (comma separated)
LANGUAGES=python,javascript,typescript,cpp

# Number of training rounds
ROUNDS=10

# Samples per round
SAMPLES_PER_ROUND=100

# Training steps per round
TRAIN_STEPS=500

# Batch size
BATCH_SIZE=1

# Learning rate
LEARNING_RATE=2e-4

# =============================================================================
# GITHUB SEARCH CONFIGURATION
# =============================================================================
# Minimum stars for repo search
MIN_STARS=100

# Minimum forks for repo search
MIN_FORKS=50

# Maximum repos to download
MAX_REPOS=50

# Search languages (comma separated)
SEARCH_LANGUAGES=python,javascript

# =============================================================================
# INFRASTRUCTURE CONFIGURATION
# =============================================================================
# Enable MLflow tracking
ENABLE_MLFLOW=true

# Enable TensorBoard
ENABLE_TENSORBOARD=true

# Enable Weights & Biases
ENABLE_WANDB=false

# Enable rich monitoring dashboard
ENABLE_DASHBOARD=true

# =============================================================================
# MONITORING CONFIGURATION
# =============================================================================
# Dashboard refresh rate (Hz)
DASHBOARD_REFRESH_RATE=2

# GPU polling interval (seconds)
GPU_POLL_INTERVAL=5

# Maximum events to display
DASHBOARD_MAX_EVENTS=20

# =============================================================================
# ADVANCED CONFIGURATION
# =============================================================================
# Base model to train
BASE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# LoRA rank
LORA_R=64

# LoRA alpha
LORA_ALPHA=16

# LoRA dropout
LORA_DROPOUT=0.1

# =============================================================================
# SECURITY & PERFORMANCE
# =============================================================================
# API request timeout (seconds)
API_TIMEOUT=30

# Maximum retry attempts
MAX_RETRIES=3

# Rate limit delay (seconds)
RATE_LIMIT_DELAY=1
